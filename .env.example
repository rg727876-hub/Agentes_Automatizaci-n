# Plantilla de variables de entorno.
# Copia este archivo como .env y completa con tus valores reales.
# El .env real NUNCA se sube al repositorio (está en .gitignore).

# --- API de Google Gemini ---
# Obtén tu clave en: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# --- Base de datos Supabase / PostgreSQL ---
# Supabase -> Project Settings -> Database -> Connection string (URI)
# Usa el "Session pooler" (compatible con IPv4) y reemplaza [YOUR-PASSWORD].
# Ejemplo: postgresql://postgres.abcdefgh:TU_PASSWORD@aws-0-us-east-1.pooler.supabase.com:5432/postgres
DATABASE_URL=

# --- Email (opcional, solo para enviar reportes) ---
EMAIL_SENDER=
EMAIL_PASSWORD=
EMAIL_SMTP_SERVER=smtp.gmail.com
EMAIL_SMTP_PORT=587

# --- Monitor automático de alertas ---
# Correo donde llegan las alertas automáticas (si no se pone, usa EMAIL_SENDER)
ALERT_EMAIL_TO=
# Cada cuántos minutos revisa el inventario (por defecto: 60)
ALERT_CHECK_INTERVAL=60
